#!/usr/bin/env bash
set -euo pipefail

# Config
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
BIN_DIR="$SCRIPT_DIR/bin"

cmd_delegate() {
    local subcommand="$1"
    shift
    local script_path="$BIN_DIR/pie-$subcommand"
    
    if [[ -x "$script_path" ]]; then
        exec "$script_path" "$@"
    else
        echo "Error: Unknown command '$subcommand' and no pie-$subcommand script found"
        cmd_help
        exit 1
    fi
}

cmd_help() {
    cat <<EOF
pie — pi environment manager

Usage: pie <command> [args...]

Commands:
EOF
    
    # Show help for available pie-* scripts with their brief descriptions
    for script in "$BIN_DIR"/pie-*; do
        if [[ -x "$script" ]]; then
            local cmd_name brief_help
            cmd_name=$(basename "$script" | sed 's/^pie-//')
            brief_help=$("$script" --brief-help 2>/dev/null || echo "(see: pie $cmd_name help)")
            printf "    %-16s %s\n" "$cmd_name" "$brief_help"
        fi
    done
    
    printf "    %-16s %s\n" "help" "Show this help"
    
    echo ""
    echo "For detailed help on any command: pie <command> help"
}

# Dispatch
case "${1:-help}" in
    init)           shift; cmd_delegate init "$@" ;;
    sandbox)        shift; cmd_delegate sandbox "$@" ;;
    help|--help|-h) cmd_help ;;
    *)              cmd_delegate "$1" "${@:2}" ;;
esac
